---
import music from '../content/music.json';

const tabs = ['Music', 'Photography', 'Travel'];
---

<section id="creative">
  <div class="container">
    <p class="label reveal">// creative</p>
    <h2 class="section-title reveal">Beyond the Terminal</h2>

    <div class="tab-bar reveal">
      {tabs.map((tab, i) => (
        <button class={`tab-btn ${i === 0 ? 'active' : ''}`} data-tab={tab.toLowerCase()}>
          {tab}
        </button>
      ))}
    </div>

    <!-- Music -->
    <div class="tab-panel active" data-panel="music">
      <a href={music.sunoProfile} target="_blank" rel="noopener noreferrer" class="suno-profile reveal">
        <div class="suno-logo">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"/>
          </svg>
        </div>
        <div>
          <p class="suno-label">Suno Profile</p>
          <p class="suno-handle">@mauri_issio</p>
        </div>
        <span class="suno-arrow">→</span>
      </a>

      <div class="music-grid">
        {music.tracks.map((track) => (
          <a href={track.url} target="_blank" rel="noopener noreferrer" class="music-card reveal">
            <div class="music-icon">♪</div>
            <div>
              <p class="music-title">{track.title}</p>
              <p class="music-desc">{track.description}</p>
              <div class="music-meta">
                <span class="label">{track.year}</span>
                <span class="label music-platform">{track.platform}</span>
              </div>
            </div>
          </a>
        ))}
        <div class="music-card reveal placeholder-card">
          <div class="music-icon">+</div>
          <div>
            <p class="music-title">More coming soon</p>
            <p class="music-desc">Add tracks to src/content/music.json</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Photography -->
    <div class="tab-panel" data-panel="photography">
      <div class="photo-grid">
        {[1,2,3,4,5,6].map((i) => (
          <div class={`photo-placeholder reveal ${i % 3 === 0 ? 'tall' : ''}`}>
            <span class="label">photo {i}</span>
          </div>
        ))}
      </div>
      <p class="placeholder-hint reveal">Add your photos to public/images/ and update this component</p>
    </div>

    <!-- Travel -->
    <div class="tab-panel" data-panel="travel">
      <div class="travel-grid">
        {['Italy', 'Japan', 'Germany', 'France', 'Portugal', 'USA'].map((country) => (
          <div class="travel-card reveal">
            <span class="travel-flag">📍</span>
            <span class="travel-name">{country}</span>
          </div>
        ))}
      </div>
      <p class="placeholder-hint reveal">Update the country list in Creative.astro</p>
    </div>

  </div>
</section>

<style>
  #creative { border-top: 1px solid var(--border); }
  .section-title { font-size: clamp(2rem, 4vw, 2.8rem); font-weight: 700; margin: 1rem 0 2.5rem; }

  .tab-bar { display: flex; gap: 0.5rem; margin-bottom: 3rem; flex-wrap: wrap; }
  .tab-btn {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    padding: 0.5rem 1.25rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--muted);
    cursor: none;
    transition: all 0.2s;
  }
  .tab-btn.active { border-color: var(--warm); color: var(--warm); background: color-mix(in srgb, var(--warm) 8%, transparent); }
  .tab-btn:hover:not(.active) { border-color: var(--text); color: var(--text); }

  .tab-panel { display: none; }
  .tab-panel.active { display: block; }

  /* Music tab centering */
  [data-panel="music"] { display: none; }
  [data-panel="music"].active {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Travel tab centering */
  [data-panel="travel"] { display: none; }
  [data-panel="travel"].active { display: block; text-align: center; }

  /* Suno profile banner */
  .suno-profile {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.5rem;
    background: color-mix(in srgb, var(--warm) 6%, var(--surface));
    border: 1px solid color-mix(in srgb, var(--warm) 30%, transparent);
    border-radius: 12px;
    max-width: 640px;
    margin-bottom: 1.5rem;
    transition: border-color 0.2s, transform 0.2s;
  }
  .suno-profile:hover { border-color: var(--warm); transform: translateX(4px); }
  .suno-logo { color: var(--warm); display: flex; align-items: center; flex-shrink: 0; }
  .suno-label { font-family: var(--font-mono); font-size: 0.72rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.08em; }
  .suno-handle { font-family: var(--font-heading); font-weight: 600; color: var(--warm); font-size: 1rem; }
  .suno-arrow { margin-left: auto; color: var(--warm); font-size: 1.1rem; }

  /* Music */
  .music-grid { display: flex; flex-direction: column; gap: 1rem; max-width: 640px; }
  .music-meta { display: flex; gap: 1rem; }
  .music-platform { color: var(--warm); }
  .music-card {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
    padding: 1.25rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    transition: border-color 0.2s, transform 0.2s;
  }
  .music-card:hover { border-color: var(--warm); transform: translateX(4px); }
  .music-card.placeholder-card { opacity: 0.4; }
  .music-icon { font-size: 1.5rem; flex-shrink: 0; margin-top: 2px; }
  .music-title { font-family: var(--font-heading); font-weight: 600; margin-bottom: 0.25rem; }
  .music-desc { font-size: 0.875rem; color: var(--muted); margin-bottom: 0.5rem; }

  /* Photography */
  .photo-grid { columns: 3 200px; gap: 0.75rem; margin-bottom: 1.5rem; }
  .photo-placeholder {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    height: 180px;
    display: flex;
    align-items: flex-end;
    padding: 0.75rem;
    margin-bottom: 0.75rem;
    break-inside: avoid;
  }
  .photo-placeholder.tall { height: 260px; }

  /* Travel */
  .travel-grid { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-bottom: 1.5rem; justify-content: center; }
  .travel-card {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.2rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    transition: border-color 0.2s;
  }
  .travel-card:hover { border-color: var(--accent); }
  .travel-name { color: var(--text); }

  /* Coding */
  .coding-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem; }
  .coding-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: border-color 0.2s, transform 0.2s;
  }
  .coding-card:hover { border-color: var(--accent); transform: translateY(-3px); }
  .card-name { font-family: var(--font-mono); font-size: 0.9rem; color: var(--accent); }
  .card-desc { font-size: 0.875rem; color: var(--muted); line-height: 1.5; flex: 1; }

  .placeholder-hint { font-size: 0.8rem; color: var(--muted); font-family: var(--font-mono); margin-top: 1rem; }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  document.querySelectorAll<HTMLElement>('.reveal').forEach((el) => {
    gsap.fromTo(el,
      { opacity: 0, y: 30 },
      { opacity: 1, y: 0, duration: 0.8, ease: 'power2.out',
        scrollTrigger: { trigger: el, start: 'top 85%' } }
    );
  });

  document.querySelectorAll('.tab-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab-btn').forEach((b) => b.classList.remove('active'));
      document.querySelectorAll('.tab-panel').forEach((p) => p.classList.remove('active'));
      btn.classList.add('active');
      const panel = document.querySelector(`.tab-panel[data-panel="${(btn as HTMLElement).dataset.tab}"]`);
      panel?.classList.add('active');
    });
  });
</script>
