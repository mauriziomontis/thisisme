---
import music from '../content/music.json';
import photosData from '../content/photos.json';
import GlobeCanvas from './GlobeCanvas.astro';
import sharp from 'sharp';
import { join } from 'path';

const tabs = ['Travel', 'Music', 'Photography'];
const BASE = import.meta.env.BASE_URL; // '/thisisme/'

const photos = await Promise.all(
  photosData.photos.map(async (photo) => {
    const filePath = join(process.cwd(), 'public', 'images', photo.src);
    const meta = await sharp(filePath).metadata();
    const tall = (meta.height ?? 0) > (meta.width ?? 0);
    return { ...photo, tall };
  })
);
---

<section id="creative">
  <div class="container">
    <p class="label reveal">// creative</p>
    <h2 class="section-title reveal">Beyond the Terminal</h2>

    <div class="tab-bar reveal">
      {tabs.map((tab, i) => (
        <button class={`tab-btn ${i === 0 ? 'active' : ''}`} data-tab={tab.toLowerCase()}>
          {tab}
        </button>
      ))}
    </div>

    <!-- Music -->
    <div class="tab-panel" data-panel="music">
      <a href={music.sunoProfile} target="_blank" rel="noopener noreferrer" class="suno-profile reveal">
        <div class="suno-logo">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 14.5v-9l6 4.5-6 4.5z"/>
          </svg>
        </div>
        <div>
          <p class="suno-label">Suno Profile</p>
          <p class="suno-handle">@mauri_issio</p>
        </div>
        <span class="suno-arrow">→</span>
      </a>

      <div class="music-grid">
        {music.tracks.map((track) => {
          const audioSrc = track.audioFile ? `${BASE}audio/${track.audioFile}` : '';
          const waveform = (
            <div class="music-waveform" aria-hidden="true">
              <svg viewBox="0 0 300 60" preserveAspectRatio="none">
                <defs>
                  <linearGradient id="waveGrad" x1="0%" y1="0%" x2="100%" y2="0%">
                    <stop offset="0%"   stop-color="var(--purple)"/>
                    <stop offset="100%" stop-color="var(--magenta)"/>
                  </linearGradient>
                </defs>
                <path d="M0,30 Q25,10 50,30 T100,30 T150,30 T200,30 T250,30 T300,30"
                      fill="none" stroke="url(#waveGrad)" stroke-width="2.5" stroke-linecap="round"/>
              </svg>
            </div>
          );
          return audioSrc ? (
            /* ── Card con player audio ─────────────────────── */
            <div class="music-card has-audio reveal" data-audio={audioSrc}>
              <div class="music-card-top">
                <div class="music-icon-badge">♪</div>
                <div class="eq-bars" aria-hidden="true">
                  <span class="eq-bar"></span>
                  <span class="eq-bar"></span>
                  <span class="eq-bar"></span>
                  <span class="eq-bar"></span>
                  <span class="eq-bar"></span>
                </div>
                <span class="track-year label">{track.year}</span>
              </div>
              {waveform}
              <p class="music-title">{track.title}</p>
              <p class="music-desc">{track.description}</p>
              <span class="label music-platform">{track.platform}</span>
              <div class="music-controls" role="group" aria-label="Player controls">
                <button class="ctrl-btn ctrl-play" aria-label="Play" type="button">
                  <svg width="13" height="13" viewBox="0 0 13 13" fill="currentColor" aria-hidden="true">
                    <path d="M2.5 1.5l9 5-9 5z"/>
                  </svg>
                </button>
                <button class="ctrl-btn ctrl-stop" aria-label="Stop" type="button">
                  <svg width="11" height="11" viewBox="0 0 11 11" fill="currentColor" aria-hidden="true">
                    <rect x="1" y="1" width="9" height="9" rx="1.5"/>
                  </svg>
                </button>
                <label class="vol-wrap">
                  <svg class="vol-icon" width="14" height="14" viewBox="0 0 14 14" fill="currentColor" aria-hidden="true">
                    <path d="M2 5h2.5L8 2v10L4.5 9H2V5z"/>
                    <path d="M9.5 4.5a3.5 3.5 0 010 5" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linecap="round"/>
                  </svg>
                  <input class="vol-slider" type="range" min="0" max="1" step="0.05" value="0.7" aria-label="Volume"/>
                </label>
              </div>
            </div>
          ) : (
            /* ── Card link esterno (Suno) ──────────────────── */
            <a href={track.url} target="_blank" rel="noopener noreferrer" class="music-card reveal">
              <div class="music-card-top">
                <div class="music-icon-badge">♪</div>
                <span class="track-year label">{track.year}</span>
              </div>
              {waveform}
              <p class="music-title">{track.title}</p>
              <p class="music-desc">{track.description}</p>
              <span class="label music-platform">{track.platform}</span>
            </a>
          );
        })}
      </div>
    </div>

    <!-- Photography -->
    <div class="tab-panel" data-panel="photography">
      <div class="photo-grid">
        {[1,2,3,4,5,6].map((i) => (
          <div class={`photo-placeholder reveal ${i % 3 === 0 ? 'tall' : ''}`}>
            <span class="label">photo {i}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Travel -->
    <div class="tab-panel active" data-panel="travel">
      <GlobeCanvas />
    </div>

  </div>
</section>

<style>
  #creative { border-top: 1px solid var(--border); }
  .section-title { font-size: clamp(2rem, 4vw, 2.8rem); font-weight: 700; margin: 1rem 0 2.5rem; }

  .tab-bar { display: flex; gap: 0.5rem; margin-bottom: 3rem; flex-wrap: wrap; }
  .tab-btn {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    padding: 0.5rem 1.25rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--muted);
    cursor: none;
    transition: all 0.2s;
  }
  .tab-btn.active { border-color: var(--purple); color: var(--purple); background: color-mix(in srgb, var(--purple) 10%, transparent); }
  .tab-btn:hover:not(.active) { border-color: var(--text); color: var(--text); }

  .tab-panel { display: none; }
  .tab-panel.active { display: block; }

  /* Music tab centering */
  [data-panel="music"] { display: none; }
  [data-panel="music"].active {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Travel tab centering */
  [data-panel="travel"] { display: none; }
  [data-panel="travel"].active { display: block; text-align: center; }

  /* Suno profile banner */
  .suno-profile {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.5rem;
    background: color-mix(in srgb, var(--warm) 6%, var(--surface));
    border: 1px solid color-mix(in srgb, var(--warm) 30%, transparent);
    border-radius: 12px;
    max-width: 640px;
    margin-bottom: 1.5rem;
    transition: border-color 0.2s, transform 0.2s;
  }
  .suno-profile:hover { border-color: var(--warm); transform: translateX(4px); }
  .suno-logo { color: var(--warm); display: flex; align-items: center; flex-shrink: 0; }
  .suno-label { font-family: var(--font-mono); font-size: 0.72rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.08em; }
  .suno-handle { font-family: var(--font-heading); font-weight: 600; color: var(--warm); font-size: 1rem; }
  .suno-arrow { margin-left: auto; color: var(--warm); font-size: 1.1rem; }

  /* Music */
  .music-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1.25rem; max-width: 860px; width: 100%; }
  .music-platform { color: var(--magenta); }
  .music-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.5rem;
    background: var(--surface-glass);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--border-glow);
    border-radius: 16px;
    transition: border-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
    text-decoration: none;
    color: inherit;
  }
  .music-card:hover {
    border-color: var(--purple);
    transform: translateY(-6px);
    box-shadow: 0 16px 40px rgba(102, 126, 234, 0.18),
                0 0 60px rgba(240, 147, 251, 0.08);
  }
  .music-card.placeholder-card { opacity: 0.35; }
  .music-card-top { display: flex; justify-content: space-between; align-items: center; }
  .music-icon-badge {
    width: 42px; height: 42px;
    display: flex; align-items: center; justify-content: center;
    background: var(--grad-creative);
    border-radius: 10px;
    font-size: 1.3rem;
    color: #fff;
  }
  .track-year { color: var(--muted); }
  .music-waveform { height: 40px; display: flex; align-items: center; }
  .music-waveform svg { width: 100%; height: 100%; }
  .music-title { font-family: var(--font-heading); font-weight: 600; font-size: 1rem; }
  .music-desc { font-size: 0.875rem; color: var(--muted); flex: 1; }

  /* Equalizer bars (animated when playing) */
  .eq-bars {
    display: flex;
    align-items: flex-end;
    gap: 3px;
    height: 22px;
    flex: 1;
    padding: 0 0.5rem;
  }
  .eq-bar {
    width: 3px;
    height: 5px;
    background: var(--grad-creative);
    border-radius: 2px;
    transition: height 0.15s;
  }
  .music-card.playing .eq-bar {
    animation: eqBounce var(--dur, 0.8s) ease-in-out infinite alternate;
  }
  .eq-bar:nth-child(1) { --dur: 0.65s; animation-delay: 0.00s; }
  .eq-bar:nth-child(2) { --dur: 0.90s; animation-delay: 0.12s; }
  .eq-bar:nth-child(3) { --dur: 0.55s; animation-delay: 0.06s; }
  .eq-bar:nth-child(4) { --dur: 1.00s; animation-delay: 0.20s; }
  .eq-bar:nth-child(5) { --dur: 0.75s; animation-delay: 0.10s; }
  @keyframes eqBounce {
    from { height: 5px;  }
    to   { height: 20px; }
  }

  /* Card playing state */
  .music-card.has-audio {
    cursor: pointer;
  }
  .music-card.playing {
    border-color: var(--purple);
    box-shadow: 0 12px 40px rgba(102,126,234,0.22),
                0 0 0 1px rgba(102,126,234,0.4);
  }

  /* Player controls */
  .music-controls {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--border);
    margin-top: auto;
  }
  .ctrl-btn {
    width: 30px;
    height: 30px;
    border-radius: 50%;
    border: 1px solid var(--border-glow);
    background: transparent;
    color: var(--muted);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    flex-shrink: 0;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
  }
  .ctrl-btn:hover { background: color-mix(in srgb, var(--purple) 15%, transparent); color: var(--purple); border-color: var(--purple); }
  .music-card.playing .ctrl-play { background: var(--grad-tech); color: #fff; border-color: transparent; }

  .vol-wrap {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-left: auto;
    color: var(--muted);
    cursor: default;
  }
  .vol-icon { flex-shrink: 0; }
  .vol-slider {
    -webkit-appearance: none;
    appearance: none;
    width: 72px;
    height: 3px;
    background: var(--border);
    border-radius: 2px;
    outline: none;
    cursor: pointer;
  }
  .vol-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--purple);
    cursor: pointer;
    box-shadow: 0 0 4px rgba(102,126,234,0.5);
  }
  .vol-slider::-moz-range-thumb {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--purple);
    border: none;
    cursor: pointer;
  }

  /* Photography */
  .photo-grid { columns: 3 200px; gap: 0.75rem; margin-bottom: 1.5rem; }
  .photo-placeholder {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    height: 180px;
    display: flex;
    align-items: flex-end;
    padding: 0.75rem;
    margin-bottom: 0.75rem;
    break-inside: avoid;
  }
  .photo-placeholder.tall { height: 260px; }

  /* Travel */
  .travel-grid { display: flex; flex-wrap: wrap; gap: 0.875rem; margin-bottom: 1.5rem; justify-content: center; }
  .glass-card {
    background: var(--surface-glass);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--border-glow);
  }
  .travel-card {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.7rem 1.4rem;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    transition: border-color 0.25s, transform 0.25s, box-shadow 0.25s;
  }
  .travel-card:hover {
    border-color: var(--purple);
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(102, 126, 234, 0.12);
  }
  .travel-name { color: var(--text); }

  /* Coding */
  .coding-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem; }
  .coding-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: border-color 0.2s, transform 0.2s;
  }
  .coding-card:hover { border-color: var(--accent); transform: translateY(-3px); }
  .card-name { font-family: var(--font-mono); font-size: 0.9rem; color: var(--accent); }
  .card-desc { font-size: 0.875rem; color: var(--muted); line-height: 1.5; flex: 1; }

  .placeholder-hint { font-size: 0.8rem; color: var(--muted); font-family: var(--font-mono); margin-top: 1rem; }

  /* ── Tablet (≤768px) ───────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .section-title { margin-bottom: 1.75rem; }

    /* Tab bar: larger tap targets */
    .tab-bar { margin-bottom: 2rem; gap: 0.4rem; }
    .tab-btn { padding: 0.45rem 1rem; font-size: 0.8rem; }

    /* Suno banner */
    .suno-profile { max-width: 100%; }

    /* Music grid: 2-up on tablet */
    .music-grid { grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); max-width: 100%; }

    /* Photography: 2-column masonry on tablet */
    .photo-grid { columns: 2 160px; }
  }

  /* ── Mobile (≤480px) ───────────────────────────────────────────────── */
  @media (max-width: 480px) {
    .section-title { margin-bottom: 1.25rem; }

    /* Tab bar: allow wrapping, full available width */
    .tab-bar { gap: 0.35rem; margin-bottom: 1.5rem; }
    .tab-btn { padding: 0.4rem 0.85rem; font-size: 0.78rem; }

    /* Suno banner: stack vertically */
    .suno-profile {
      max-width: 100%;
      flex-wrap: wrap;
      gap: 0.5rem;
    }

    /* Music: single column */
    .music-grid { grid-template-columns: 1fr; max-width: 100%; }

    /* Music card: tighter padding */
    .music-card { padding: 1.1rem; }

    /* Player controls: tighter */
    .music-controls { gap: 0.4rem; }
    .vol-slider { width: 52px; }

    /* Photography: single column */
    .photo-grid { columns: 1; }
    .photo-placeholder { height: 160px; }
    .photo-placeholder.tall { height: 220px; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  document.querySelectorAll<HTMLElement>('.reveal').forEach((el) => {
    gsap.fromTo(el,
      { opacity: 0, y: 30 },
      { opacity: 1, y: 0, duration: 0.8, ease: 'power2.out',
        scrollTrigger: { trigger: el, start: 'top 85%' } }
    );
  });

  document.querySelectorAll('.tab-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.tab-btn').forEach((b) => b.classList.remove('active'));
      document.querySelectorAll('.tab-panel').forEach((p) => p.classList.remove('active'));
      btn.classList.add('active');
      const tab = (btn as HTMLElement).dataset.tab;
      const panel = document.querySelector(`.tab-panel[data-panel="${tab}"]`);
      panel?.classList.add('active');
      if (tab === 'travel') document.dispatchEvent(new CustomEvent('travel-tab-activated'));
      document.dispatchEvent(new CustomEvent('creative-tab-changed', { detail: { tab } }));
    });
  });

  // ── Audio player ────────────────────────────────────────────────────────────
  const ICON_PLAY  = `<svg width="13" height="13" viewBox="0 0 13 13" fill="currentColor" aria-hidden="true"><path d="M2.5 1.5l9 5-9 5z"/></svg>`;
  const ICON_PAUSE = `<svg width="13" height="13" viewBox="0 0 13 13" fill="currentColor" aria-hidden="true"><rect x="2" y="2" width="3.5" height="9" rx="1"/><rect x="7.5" y="2" width="3.5" height="9" rx="1"/></svg>`;

  let activeAudio: HTMLAudioElement | null = null;
  let activeCard:  HTMLElement | null = null;

  function setPlayUI(card: HTMLElement, playing: boolean) {
    card.classList.toggle('playing', playing);
    const btn = card.querySelector<HTMLButtonElement>('.ctrl-play');
    if (!btn) return;
    btn.innerHTML = playing ? ICON_PAUSE : ICON_PLAY;
    btn.setAttribute('aria-label', playing ? 'Pause' : 'Play');
  }

  function stopAll() {
    if (activeAudio) { activeAudio.pause(); activeAudio.currentTime = 0; }
    if (activeCard)  setPlayUI(activeCard, false);
    activeAudio = null;
    activeCard  = null;
  }

  document.querySelectorAll<HTMLElement>('.music-card.has-audio').forEach(card => {
    const src       = card.dataset.audio!;
    const playBtn   = card.querySelector<HTMLButtonElement>('.ctrl-play')!;
    const stopBtn   = card.querySelector<HTMLButtonElement>('.ctrl-stop')!;
    const volSlider = card.querySelector<HTMLInputElement>('.vol-slider')!;

    function togglePlay() {
      // same card, audio paused → resume
      if (activeCard === card && activeAudio?.paused) {
        activeAudio.play();
        setPlayUI(card, true);
        return;
      }
      // same card, audio playing → pause
      if (activeCard === card && activeAudio && !activeAudio.paused) {
        activeAudio.pause();
        setPlayUI(card, false);
        return;
      }
      // different card → stop current, start new
      stopAll();
      const audio = new Audio(src);
      audio.volume = parseFloat(volSlider.value);
      audio.play().catch(e => console.warn('[Audio]', e));
      audio.addEventListener('ended', stopAll);
      activeAudio = audio;
      activeCard  = card;
      setPlayUI(card, true);
    }

    // play/pause button
    playBtn.addEventListener('click', e => { e.stopPropagation(); togglePlay(); });
    // stop button
    stopBtn.addEventListener('click', e => { e.stopPropagation(); stopAll(); });
    // volume slider — don't bubble to card click
    volSlider.addEventListener('click',  e => e.stopPropagation());
    volSlider.addEventListener('input',  () => {
      if (activeCard === card && activeAudio) {
        activeAudio.volume = parseFloat(volSlider.value);
      }
    });
    // click on card body → toggle play
    card.addEventListener('click', togglePlay);
  });
</script>
