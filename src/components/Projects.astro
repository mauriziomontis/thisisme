---
interface Repo {
  id: number;
  name: string;
  description: string | null;
  html_url: string;
  stargazers_count: number;
  language: string | null;
  topics: string[];
}

import projectsConfig from '../content/projects.json';
import githubCache from '../content/github-cache.json';
const { featured } = projectsConfig;

let repos: Repo[] = [];
try {
  const token = import.meta.env.GH_TOKEN;
  const headers: Record<string, string> = { 'Accept': 'application/vnd.github.v3+json' };
  if (token) headers['Authorization'] = `Bearer ${token}`;
  const res = await fetch('https://api.github.com/users/mauriziomontis/repos?per_page=100&sort=updated', { headers });
  if (res.ok) repos = await res.json();
} catch (_) {}

if (repos.length === 0) repos = githubCache as Repo[];

// Se la lista featured è vuota mostra placeholder, altrimenti filtra per nome
const filtered = featured.length > 0
  ? repos.filter((r) => featured.includes(r.name))
  : [];
---

<section id="projects">
  <div class="container">
    <p class="label reveal">// projects</p>
    <h2 class="section-title reveal">Open Source &<br/>Side Projects</h2>

    {filtered.length > 0 ? (
      <div class="projects-grid" id="projects-grid">
        {filtered.map((repo) => (
          <a
            href={repo.html_url}
            target="_blank"
            rel="noopener noreferrer"
            class="project-card reveal"
            data-topics={repo.topics.join(',')}
          >
            <div class="card-header">
              <span class="card-name">{repo.name}</span>
              <svg class="card-arrow" width="16" height="16" viewBox="0 0 16 16" fill="none">
                <path d="M3 13L13 3M13 3H6M13 3V10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              </svg>
            </div>
            <p class="card-desc">{repo.description || 'No description available.'}</p>
            <div class="card-meta">
              {repo.language && <span class="card-lang">{repo.language}</span>}
              <span class="card-stars">⭐ {repo.stargazers_count}</span>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div class="projects-grid" id="projects-grid">
        {[1,2,3,4,5,6].map((i) => (
          <div class="project-card reveal placeholder-card">
            <div class="card-header">
              <span class="card-name">project-{i}</span>
            </div>
            <div class="card-meta">
              <span class="card-lang">TypeScript</span>
              <span class="card-stars">⭐ 0</span>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</section>

<style>
  #projects { border-top: 1px solid var(--border); }
  .section-title {
    font-size: clamp(2rem, 4vw, 2.8rem);
    font-weight: 700;
    margin-bottom: 3rem;
    margin-top: 1rem;
  }
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
  }
  .project-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
  }
  .project-card:hover {
    transform: translateY(-6px);
    border-color: var(--border-glow);
    box-shadow: 0 12px 40px rgba(102, 126, 234, 0.15),
                0 0 0 1px var(--border-glow);
  }
  .placeholder-card { opacity: 0.4; }
  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }
  .card-name {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--text);
    word-break: break-all;
  }
  .card-arrow {
    color: var(--muted);
    flex-shrink: 0;
    margin-left: 0.5rem;
    margin-top: 2px;
  }
  .project-card:hover .card-arrow { color: var(--primary); }
  .card-desc {
    font-size: 0.875rem;
    color: var(--muted);
    line-height: 1.6;
    flex: 1;
  }
  .card-meta {
    display: flex;
    gap: 1rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--muted);
  }
  .card-lang { color: var(--accent); }
  .hidden { display: none; }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  document.querySelectorAll<HTMLElement>('.reveal').forEach((el) => {
    gsap.fromTo(el,
      { opacity: 0, y: 30 },
      { opacity: 1, y: 0, duration: 0.8, ease: 'power2.out',
        scrollTrigger: { trigger: el, start: 'top 85%' } }
    );
  });

</script>
