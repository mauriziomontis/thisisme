---
import data from '../content/right-now.json';
const { exploring, listening, thoughts } = data;
---

{(exploring.length > 0 || listening || thoughts.length > 0) && (
  <div class="right-now reveal">
    {exploring.length > 0 && (
      <div class="rn-row">
        <span class="rn-label">// exploring</span>
        <span class="rn-tags">
          {exploring.map((tag) => <span class="rn-tag">{tag}</span>)}
        </span>
      </div>
    )}
    {listening && (
      <div class="rn-row">
        <span class="rn-label">// listening</span>
        <span class="rn-val">{listening}</span>
      </div>
    )}
    {thoughts.length > 0 && (
      <div class="rn-row">
        <span class="rn-label">// thinking</span>
        <span class="rn-thought" data-thoughts={JSON.stringify(thoughts)}></span>
      </div>
    )}
  </div>
)}

<style>
  .right-now {
    margin-top: 2rem;
    padding-top: 1.75rem;
    border-top: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    max-width: 540px;
  }
  .rn-row {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .rn-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--muted);
    min-width: 100px;
    flex-shrink: 0;
  }
  .rn-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }
  .rn-tag {
    font-family: var(--font-mono);
    font-size: 0.76rem;
    padding: 2px 10px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--purple) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--purple) 30%, transparent);
    color: var(--primary);
  }
  .rn-val {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text);
  }
  .rn-thought {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--muted);
    font-style: italic;
  }

  @media (max-width: 768px) {
    .right-now { max-width: 100%; }
    .rn-row {
      align-items: flex-start;
      gap: 0.5rem;
    }
    .rn-label { min-width: 85px; }
  }

  @media (max-width: 480px) {
    .rn-row {
      flex-direction: column;
      gap: 0.35rem;
    }
    .rn-label { min-width: unset; }
    .rn-tags { gap: 0.3rem; }
    .rn-tag {
      font-size: 0.72rem;
      padding: 3px 8px;
    }
    .rn-val,
    .rn-thought { font-size: 0.8rem; }
  }
</style>

<script>
  const el = document.querySelector<HTMLElement>('.rn-thought');
  if (el?.dataset.thoughts) {
    const thoughts: string[] = JSON.parse(el.dataset.thoughts);
    if (thoughts.length > 0)
      el.textContent = thoughts[Math.floor(Math.random() * thoughts.length)];
  }
</script>
