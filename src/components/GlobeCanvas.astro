---
import travel from '../content/travel.json';
import metrics from '../content/metrics.json';
const BASE = import.meta.env.BASE_URL; // '/thisisme/'

const countriesVisited  = travel.visited.length;
const continentsVisited = new Set(travel.visited.map(c => c.continent)).size;
const kmFormatted = metrics.kmTravelled >= 1000
  ? `${Math.round(metrics.kmTravelled / 1000)}k`
  : metrics.kmTravelled.toString();

const earthLaps   = Math.round(metrics.kmTravelled / 40075 * 10) / 10;
const daysInFlight = Math.round(metrics.kmTravelled / 900 / 24);

// 1 colonna ogni 10 paesi, max 3
const legendCols = Math.min(Math.ceil(travel.visited.length / 10), 3);

const travelStats = [
  { value: countriesVisited,  label: 'countries'  },
  { value: continentsVisited, label: 'continents' },
  { value: metrics.flights,   label: 'flights'    },
  { value: kmFormatted,       label: 'km', sub: `${earthLaps}× Earth · ${daysInFlight} days in flight` },
];
---

<div class="globe-layout">
  <div class="globe-wrap">
    <canvas
      id="globe-canvas"
      data-visited={JSON.stringify(travel.visited.map(c => c.isoNum))}
      data-topo-url={`${BASE}data/countries-110m.json`}
      aria-label="World map — visited countries highlighted"
    ></canvas>
    <p class="globe-hint">drag to rotate</p>
  </div>

  <div class="globe-legend">
    <div class="travel-stats">
      {travelStats.map(s => (
        <div class="travel-stat">
          <span class="ts-value">{s.value}</span>
          <span class="ts-label">{s.label}</span>
          {s.sub && <span class="ts-sub">{s.sub}</span>}
        </div>
      ))}
    </div>
    <p class="legend-title label">Visited ({countriesVisited})</p>
    <ul class="legend-list" style={`column-count: ${legendCols}`}>
      {travel.visited.map(c => (
        <li class="legend-item">
          <span class="legend-flag">{c.flag}</span>
          <span class="legend-name">{c.name}</span>
        </li>
      ))}
    </ul>
  </div>
</div>

<style>
  .globe-layout {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 3rem;
    flex-wrap: wrap;
    padding: 1rem 0 2rem;
  }
  .globe-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }
  #globe-canvas {
    width: 440px;
    height: 440px;
    border-radius: 50%;
    cursor: grab;
    display: block;
    box-shadow:
      0 0 40px rgba(102,126,234,0.18),
      0 0 80px rgba(102,126,234,0.06),
      0 0  4px rgba(102,126,234,0.30);
    transition: box-shadow 0.3s ease;
  }
  #globe-canvas:hover {
    box-shadow:
      0 0 60px rgba(102,126,234,0.28),
      0 0 120px rgba(102,126,234,0.10),
      0 0   6px rgba(102,126,234,0.40);
  }
  #globe-canvas:active { cursor: grabbing; }
  .globe-hint {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--muted);
    letter-spacing: 0.08em;
    opacity: 0.6;
  }
  .globe-legend {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .travel-stats {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }
  .travel-stat {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: 0.5rem 0.85rem;
    background: var(--surface-glass);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--border-glow);
    border-radius: 10px;
    min-width: 64px;
    transition: border-color 0.25s, transform 0.25s;
  }
  .travel-stat:hover { border-color: var(--purple); transform: translateY(-2px); }
  .ts-value {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 700;
    line-height: 1;
    background: var(--grad-tech);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .ts-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin-top: 0.25rem;
  }
  .ts-sub {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--muted);
    opacity: 0.65;
    margin-top: 0.3rem;
    white-space: nowrap;
  }
  .legend-title { margin-bottom: 0.5rem; }
  .legend-list { list-style: none; column-gap: 2rem; }
  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--muted);
    transition: color 0.2s;
    break-inside: avoid;
    padding-bottom: 0.6rem;
  }
  .legend-item:hover { color: var(--text); }
  .legend-flag { font-size: 1.2rem; line-height: 1; }

  @media (max-width: 700px) {
    #globe-canvas { width: 300px; height: 300px; }
    .globe-layout { gap: 1.5rem; }
    .legend-list { column-count: 2 !important; }
  }
</style>

<script>
  const canvas = document.getElementById('globe-canvas') as HTMLCanvasElement;
  if (!canvas) throw new Error('globe-canvas missing');

  let initialized = false;

  async function initGlobe() {
    if (initialized) return;
    initialized = true;

    const [{ geoOrthographic, geoPath, geoGraticule }, { feature }] = await Promise.all([
      import('d3-geo'),
      import('topojson-client'),
    ]);

    const ctx        = canvas.getContext('2d')!;
    const visitedSet = new Set<number>(JSON.parse(canvas.dataset.visited || '[]'));
    const topoUrl    = canvas.dataset.topoUrl!;

    // Canvas size hardcoded to avoid getBoundingClientRect()=0 when panel is display:none
    const CSS_SIZE = window.innerWidth < 700 ? 300 : 440;
    const dpr      = Math.min(window.devicePixelRatio || 1, 2);
    canvas.width   = CSS_SIZE * dpr;
    canvas.height  = CSS_SIZE * dpr;
    ctx.scale(dpr, dpr);

    const SIZE = CSS_SIZE;

    const projection = geoOrthographic()
      .scale(SIZE / 2 - 3)
      .translate([SIZE / 2, SIZE / 2])
      .clipAngle(90)
      .rotate([-10, 15]);

    const pathGen   = geoPath(projection, ctx);
    const graticule = geoGraticule()();

    const BG      = '#0a0a0f';
    const SURFACE = 'rgba(17,17,24,0.94)';
    const GRID    = 'rgba(30,30,46,0.40)';
    const BORDER  = 'rgba(30,30,46,0.60)';
    const V_FILL  = 'rgba(102,126,234,0.48)';
    const V_LINE  = '#667eea';
    const OUTLINE = 'rgba(102,126,234,0.22)';

    let lambda = -10, phi = 15;
    let dragging = false, lastX = 0, lastY = 0;
    const AUTO    = 0.13;
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // eslint-disable-next-line @typescript-eslint/no-explicit-any
    let features: any[] = [];

    function render() {
      projection.rotate([lambda, phi]);
      ctx.clearRect(0, 0, SIZE, SIZE);

      ctx.beginPath();
      // @ts-ignore
      pathGen({ type: 'Sphere' });
      ctx.fillStyle = BG;
      ctx.fill();

      ctx.beginPath();
      // @ts-ignore
      pathGen(graticule);
      ctx.strokeStyle = GRID;
      ctx.lineWidth   = 0.4;
      ctx.stroke();

      for (const f of features) {
        const id        = typeof f.id === 'string' ? parseInt(f.id, 10) : Number(f.id);
        const isVisited = visitedSet.has(id);

        ctx.beginPath();
        // @ts-ignore
        pathGen(f);

        if (isVisited) {
          ctx.fillStyle = V_FILL;
          ctx.fill();
          ctx.save();
          ctx.shadowColor = V_LINE;
          ctx.shadowBlur  = 8 * dpr;
          ctx.strokeStyle = V_LINE;
          ctx.lineWidth   = 1.0;
          ctx.stroke();
          ctx.restore();
        } else {
          ctx.fillStyle   = SURFACE;
          ctx.fill();
          ctx.strokeStyle = BORDER;
          ctx.lineWidth   = 0.3;
          ctx.stroke();
        }
      }

      ctx.beginPath();
      // @ts-ignore
      pathGen({ type: 'Sphere' });
      ctx.strokeStyle = OUTLINE;
      ctx.lineWidth   = 1.5;
      ctx.stroke();
    }

    function animate() {
      if (!dragging && !reduced) lambda += AUTO;
      render();
      requestAnimationFrame(animate);
    }

    canvas.addEventListener('mousedown', e => {
      dragging = true; lastX = e.clientX; lastY = e.clientY;
    });
    window.addEventListener('mousemove', e => {
      if (!dragging) return;
      lambda += (e.clientX - lastX) * 0.45;
      phi    -= (e.clientY - lastY) * 0.30;
      phi     = Math.max(-80, Math.min(80, phi));
      lastX   = e.clientX; lastY = e.clientY;
    });
    window.addEventListener('mouseup', () => { dragging = false; });

    canvas.addEventListener('touchstart', e => {
      dragging = true;
      lastX = e.touches[0].clientX;
      lastY = e.touches[0].clientY;
    }, { passive: true });
    window.addEventListener('touchmove', e => {
      if (!dragging) return;
      lambda += (e.touches[0].clientX - lastX) * 0.45;
      phi    -= (e.touches[0].clientY - lastY) * 0.30;
      phi     = Math.max(-80, Math.min(80, phi));
      lastX   = e.touches[0].clientX;
      lastY   = e.touches[0].clientY;
    }, { passive: true });
    window.addEventListener('touchend', () => { dragging = false; });

    fetch(topoUrl)
      .then(r => {
        if (!r.ok) throw new Error(`HTTP ${r.status} fetching ${topoUrl}`);
        return r.json();
      })
      .then(topo => {
        const obj = topo.objects?.countries ?? topo.objects?.land;
        if (!obj) throw new Error('No countries object in topology');
        const geojson = feature(topo, obj) as GeoJSON.FeatureCollection;
        features = geojson.features;
      })
      .catch(err => console.error('[GlobeCanvas] topology load failed:', err))
      .finally(() => animate());
  }

  // Init when travel tab is first activated
  document.addEventListener('travel-tab-activated', initGlobe, { once: true });

  // Also init if travel tab is already active on load
  const panel = canvas.closest('[data-panel="travel"]');
  if (panel?.classList.contains('active')) initGlobe();
</script>
