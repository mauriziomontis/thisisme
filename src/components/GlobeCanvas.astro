---
import travel from '../content/travel.json';
const BASE = import.meta.env.BASE_URL; // '/thisisme/'
---

<div class="globe-layout">
  <div class="globe-wrap">
    <canvas
      id="globe-canvas"
      data-visited={JSON.stringify(travel.visited.map(c => c.isoNum))}
      data-topo-url={`${BASE}data/countries-110m.json`}
      aria-label="World map — visited countries highlighted"
    ></canvas>
    <p class="globe-hint">drag to rotate</p>
  </div>

  <div class="globe-legend">
    <p class="legend-title label">Visited ({travel.visited.length})</p>
    <ul class="legend-list">
      {travel.visited.map(c => (
        <li class="legend-item">
          <span class="legend-flag">{c.flag}</span>
          <span class="legend-name">{c.name}</span>
        </li>
      ))}
    </ul>
  </div>
</div>

<style>
  .globe-layout {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 3rem;
    flex-wrap: wrap;
    padding: 1rem 0 2rem;
  }
  .globe-wrap {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }
  #globe-canvas {
    width: 440px;
    height: 440px;
    border-radius: 50%;
    cursor: grab;
    display: block;
    box-shadow:
      0 0 40px rgba(102,126,234,0.18),
      0 0 80px rgba(102,126,234,0.06),
      0 0  4px rgba(102,126,234,0.30);
    transition: box-shadow 0.3s ease;
  }
  #globe-canvas:hover {
    box-shadow:
      0 0 60px rgba(102,126,234,0.28),
      0 0 120px rgba(102,126,234,0.10),
      0 0   6px rgba(102,126,234,0.40);
  }
  #globe-canvas:active { cursor: grabbing; }
  .globe-hint {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--muted);
    letter-spacing: 0.08em;
    opacity: 0.6;
  }
  .globe-legend {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .legend-title { margin-bottom: 0.5rem; }
  .legend-list { list-style: none; display: flex; flex-direction: column; gap: 0.6rem; }
  .legend-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--muted);
    transition: color 0.2s;
  }
  .legend-item:hover { color: var(--text); }
  .legend-flag { font-size: 1.2rem; line-height: 1; }

  @media (max-width: 700px) {
    #globe-canvas { width: 300px; height: 300px; }
    .globe-layout { gap: 1.5rem; }
    .legend-list { flex-direction: row; flex-wrap: wrap; gap: 0.75rem 1.5rem; }
  }
</style>

<script>
  import { geoOrthographic, geoPath, geoGraticule } from 'd3-geo';
  import { feature } from 'topojson-client';

  const canvas  = document.getElementById('globe-canvas') as HTMLCanvasElement;
  if (!canvas) throw new Error('globe-canvas missing');

  const ctx         = canvas.getContext('2d')!;
  const visitedSet  = new Set<number>(JSON.parse(canvas.dataset.visited || '[]'));
  const topoUrl     = canvas.dataset.topoUrl!;

  // ── Canvas size — hardcoded to match CSS, avoids getBoundingClientRect()=0
  // when the tab panel is display:none at init time.
  const CSS_SIZE  = window.innerWidth < 700 ? 300 : 440;
  const dpr       = Math.min(window.devicePixelRatio || 1, 2);
  canvas.width    = CSS_SIZE * dpr;
  canvas.height   = CSS_SIZE * dpr;
  ctx.scale(dpr, dpr);

  const SIZE = CSS_SIZE; // working unit in CSS pixels

  // ── D3 setup ──────────────────────────────────────────────────────────────
  const projection = geoOrthographic()
    .scale(SIZE / 2 - 3)
    .translate([SIZE / 2, SIZE / 2])
    .clipAngle(90)
    .rotate([-10, 15]);

  const pathGen   = geoPath(projection, ctx);
  const graticule = geoGraticule()();

  // ── Colors ────────────────────────────────────────────────────────────────
  const BG      = '#0a0a0f';
  const SURFACE = 'rgba(17,17,24,0.94)';
  const GRID    = 'rgba(30,30,46,0.40)';
  const BORDER  = 'rgba(30,30,46,0.60)';
  const V_FILL  = 'rgba(102,126,234,0.48)';
  const V_LINE  = '#667eea';
  const OUTLINE = 'rgba(102,126,234,0.22)';

  // ── Rotation state ────────────────────────────────────────────────────────
  let lambda = -10, phi = 15;
  let dragging = false, lastX = 0, lastY = 0;
  const AUTO    = 0.13;
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // ── Country features ──────────────────────────────────────────────────────
  // eslint-disable-next-line @typescript-eslint/no-explicit-any
  let features: any[] = [];

  // ── Render ────────────────────────────────────────────────────────────────
  function render() {
    projection.rotate([lambda, phi]);
    ctx.clearRect(0, 0, SIZE, SIZE);

    // Sphere fill
    ctx.beginPath();
    // @ts-ignore — Sphere is a valid d3-geo object
    pathGen({ type: 'Sphere' });
    ctx.fillStyle = BG;
    ctx.fill();

    // Graticule
    ctx.beginPath();
    // @ts-ignore
    pathGen(graticule);
    ctx.strokeStyle = GRID;
    ctx.lineWidth   = 0.4;
    ctx.stroke();

    // Countries
    for (const f of features) {
      const id        = typeof f.id === 'string' ? parseInt(f.id, 10) : Number(f.id);
      const isVisited = visitedSet.has(id);

      ctx.beginPath();
      // @ts-ignore
      pathGen(f);

      if (isVisited) {
        ctx.fillStyle = V_FILL;
        ctx.fill();
        ctx.save();
        ctx.shadowColor = V_LINE;
        ctx.shadowBlur  = 8 * dpr;
        ctx.strokeStyle = V_LINE;
        ctx.lineWidth   = 1.0;
        ctx.stroke();
        ctx.restore();
      } else {
        ctx.fillStyle   = SURFACE;
        ctx.fill();
        ctx.strokeStyle = BORDER;
        ctx.lineWidth   = 0.3;
        ctx.stroke();
      }
    }

    // Sphere outline
    ctx.beginPath();
    // @ts-ignore
    pathGen({ type: 'Sphere' });
    ctx.strokeStyle = OUTLINE;
    ctx.lineWidth   = 1.5;
    ctx.stroke();
  }

  // ── Animation loop ────────────────────────────────────────────────────────
  function animate() {
    if (!dragging && !reduced) lambda += AUTO;
    render();
    requestAnimationFrame(animate);
  }

  // ── Drag — mouse ──────────────────────────────────────────────────────────
  canvas.addEventListener('mousedown', e => {
    dragging = true; lastX = e.clientX; lastY = e.clientY;
  });
  window.addEventListener('mousemove', e => {
    if (!dragging) return;
    lambda += (e.clientX - lastX) * 0.45;
    phi    -= (e.clientY - lastY) * 0.30;
    phi     = Math.max(-80, Math.min(80, phi));
    lastX   = e.clientX; lastY = e.clientY;
  });
  window.addEventListener('mouseup', () => { dragging = false; });

  // ── Drag — touch ──────────────────────────────────────────────────────────
  canvas.addEventListener('touchstart', e => {
    dragging = true;
    lastX = e.touches[0].clientX;
    lastY = e.touches[0].clientY;
  }, { passive: true });
  window.addEventListener('touchmove', e => {
    if (!dragging) return;
    lambda += (e.touches[0].clientX - lastX) * 0.45;
    phi    -= (e.touches[0].clientY - lastY) * 0.30;
    phi     = Math.max(-80, Math.min(80, phi));
    lastX   = e.touches[0].clientX;
    lastY   = e.touches[0].clientY;
  }, { passive: true });
  window.addEventListener('touchend', () => { dragging = false; });

  // ── Load topology and start ───────────────────────────────────────────────
  fetch(topoUrl)
    .then(r => {
      if (!r.ok) throw new Error(`HTTP ${r.status} fetching ${topoUrl}`);
      return r.json();
    })
    .then(topo => {
      // world-atlas countries-110m.json uses 'countries' as the object key
      const obj = topo.objects?.countries ?? topo.objects?.land;
      if (!obj) throw new Error('No countries object in topology');
      const geojson = feature(topo, obj) as GeoJSON.FeatureCollection;
      features = geojson.features;
    })
    .catch(err => console.error('[GlobeCanvas] topology load failed:', err))
    .finally(() => animate());
</script>
