---
---
<section id="contact">
  <div class="container">
    <p class="label reveal">// contact</p>
    <div class="contact-body reveal">
      <div class="contact-text">
        <h2 class="section-title">Say Hello</h2>
        <p class="contact-sub">I'm always happy to connect — whether it's about projects, music, or just a good conversation.</p>
      </div>
      <div class="contact-links">
        <a href="https://github.com/mauriziomontis" target="_blank" rel="noopener noreferrer" class="contact-link" data-magnetic>
          <span class="contact-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/>
            </svg>
          </span>
          <span>GitHub</span>
        </a>
        <a href="https://www.linkedin.com/in/maurizio-montis/" target="_blank" rel="noopener noreferrer" class="contact-link" data-magnetic>
          <span class="contact-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </span>
          <span>LinkedIn</span>
        </a>
      </div>
    </div>

    <p class="footer-note reveal">Built with Astro · Animated with GSAP · Deployed on GitHub Pages</p>
  </div>
</section>

<style>
  #contact {
    border-top: 1px solid var(--border);
    padding-bottom: 8rem;
  }
  .contact-body {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 3rem;
    margin-bottom: 4rem;
  }
  .contact-text { flex: 1; }
  .section-title { font-size: clamp(2rem, 4vw, 2.8rem); font-weight: 700; margin: 0 0 1rem; }
  .contact-sub { color: var(--muted); max-width: 420px; line-height: 1.7; }
  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex-shrink: 0;
  }
  .contact-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.875rem 1.75rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--muted);
    background: var(--surface);
    transition: all 0.25s;
    white-space: nowrap;
  }
  .contact-link:hover {
    border-color: var(--primary);
    color: var(--text);
    background: color-mix(in srgb, var(--primary) 6%, var(--surface));
    transform: translateX(-3px);
  }
  .contact-icon { display: flex; align-items: center; font-size: 1rem; }
  .footer-note { font-family: var(--font-mono); font-size: 0.75rem; color: var(--border); }

  @media (max-width: 768px) {
    .contact-body {
      flex-direction: column;
      align-items: flex-start;
      gap: 2rem;
      margin-bottom: 2.5rem;
    }
    .contact-links {
      width: 100%;
      flex-direction: row;
      flex-wrap: wrap;
      gap: 0.75rem;
    }
    .contact-link {
      flex: 1 1 auto;
      justify-content: center;
      min-width: 140px;
    }
  }

  @media (max-width: 480px) {
    #contact { padding-bottom: 5rem; }
    .contact-body { gap: 1.5rem; }
    .contact-sub { max-width: 100%; }
    .contact-links {
      flex-direction: column;
      width: 100%;
    }
    .contact-link {
      width: 100%;
      justify-content: flex-start;
      padding: 0.875rem 1.25rem;
      min-height: 48px;
    }
    .footer-note { font-size: 0.7rem; line-height: 1.6; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  document.querySelectorAll<HTMLElement>('#contact .reveal').forEach((el) => {
    gsap.fromTo(el,
      { opacity: 0, y: 20 },
      { opacity: 1, y: 0, duration: 0.7, ease: 'power2.out',
        scrollTrigger: { trigger: el, start: 'top 88%' } }
    );
  });
</script>
