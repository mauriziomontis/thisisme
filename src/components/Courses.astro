---
import courses from '../content/courses.json';
---

<section id="courses">
  <div class="container">
    <p class="label reveal">// courses</p>
    <h2 class="section-title reveal">Training Materials</h2>
    <div class="courses-list">
      {courses.map((course) => (
        <a href={course.url} target="_blank" rel="noopener noreferrer" class="course-item reveal">
          <div class="course-info">
            <span class="course-title">{course.title}</span>
            <span class="course-desc">{course.description}</span>
          </div>
          <div class="course-right">
            <span class="label">{course.year}</span>
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
              <path d="M4 16L16 4M16 4H8M16 4V12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  #courses { border-top: 1px solid var(--border); }
  .section-title { font-size: clamp(2rem, 4vw, 2.8rem); font-weight: 700; margin: 1rem 0 2.5rem; }
  .courses-list { display: flex; flex-direction: column; gap: 0; max-width: 720px; }
  .course-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--border);
    gap: 1rem;
    transition: padding-left 0.3s ease;
  }
  .course-item:hover { padding-left: 1rem; }
  .course-item:hover svg { color: var(--primary); }
  .course-info { display: flex; flex-direction: column; gap: 0.25rem; }
  .course-title { font-family: var(--font-heading); font-weight: 600; font-size: 1.1rem; color: var(--text); }
  .course-desc { font-size: 0.875rem; color: var(--muted); }
  .course-right { display: flex; align-items: center; gap: 1rem; color: var(--muted); flex-shrink: 0; }
  svg { transition: color 0.2s; }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  document.querySelectorAll<HTMLElement>('#courses .reveal').forEach((el, i) => {
    gsap.fromTo(el,
      { opacity: 0, y: 20 },
      { opacity: 1, y: 0, duration: 0.6, delay: i * 0.1, ease: 'power2.out',
        scrollTrigger: { trigger: el, start: 'top 88%' } }
    );
  });
</script>
