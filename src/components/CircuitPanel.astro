    <!-- ═══════════════════════════════ GROUP F (600–720) ═════════════════════ -->
    <circle class="cd" cx="40" cy="615" r="3.5"/>
    <line class="cp" x1="12" y1="615" x2="40" y2="615" stroke-width="1.5"/>
    <rect class="cpd" x="8" y="610" width="9" height="9"/>

    <circle class="cd" cx="40" cy="645" r="3.5"/>
    <line class="cp" x1="40" y1="645" x2="61" y2="645" stroke-width="1.5"/>
    <line class="cp" x1="61" y1="645" x2="61" y2="670" stroke-width="1.5"/>
    <circle class="cd" cx="61" cy="670" r="3"/>
    <line class="cp" x1="61" y1="670" x2="73" y2="670" stroke-width="1.5"/>

    <circle class="cd" cx="40" cy="696" r="3.5"/>
    <line class="cp" x1="16" y1="696" x2="40" y2="696" stroke-width="1.5"/>

    <!-- ═══════════════════════════════ GROUP G (720–800) ═════════════════════ -->
    <circle class="cd" cx="40" cy="736" r="3.5"/>
    <line class="cp" x1="40" y1="736" x2="70" y2="736" stroke-width="1.5"/>
    <rect class="cpd" x="67" y="731" width="9" height="9"/>

    <circle class="cd" cx="40" cy="762" r="3.5"/>
    <line class="cp" x1="18" y1="762" x2="40" y2="762" stroke-width="1.5"/>
    <line class="cp" x1="18" y1="762" x2="18" y2="782" stroke-width="1.5"/>
    <circle class="cd" cx="18" cy="782" r="3"/>

    <circle class="cd" cx="40" cy="793" r="3.5"/>

    <!-- ══════════════════ FLOW TRACES (electricity animation) ════════════════ -->
    <!-- flowing down backbone top -->
    <line class="cf cf-slow"  x1="40" y1="0"   x2="40" y2="200" stroke-width="1.5"/>
    <!-- flowing right, group A -->
    <line class="cf"          x1="40" y1="25"  x2="70" y2="25"  stroke-width="1"/>
    <!-- flowing down backbone mid -->
    <line class="cf cf-rev"   x1="40" y1="300" x2="40" y2="500" stroke-width="1.5"/>
    <!-- flowing left, group D -->
    <line class="cf cf-rev"   x1="10" y1="375" x2="40" y2="375" stroke-width="1"/>
    <!-- flowing right, group E -->
    <line class="cf cf-fast"  x1="40" y1="498" x2="71" y2="498" stroke-width="1"/>
    <!-- flowing down backbone bottom -->
    <line class="cf cf-slow"  x1="40" y1="600" x2="40" y2="800" stroke-width="1.5"/>
  </svg>
</div>

<style>
  #circuit-panel {
    position: fixed;
    right: 0;
    top: 0;
    width: 80px;
    height: 100vh;
    z-index: 50;
    pointer-events: none;
    mask-image: linear-gradient(to bottom,
      transparent 0%,
      black 8%,
      black 92%,
      transparent 100%
    );
    opacity: 0.85;
  }

  #circuit-svg {
    width: 100%;
    height: 100%;
  }

  /* Base circuit elements — color controlled via JS */
  .cp {
    stroke: #4f8ef7;
    fill: none;
    stroke-linecap: round;
    transition: stroke 0.9s ease, filter 0.9s ease;
    filter: drop-shadow(0 0 3px #4f8ef7);
  }
  .cd {
    fill: #4f8ef7;
    transition: fill 0.9s ease, filter 0.9s ease;
    filter: drop-shadow(0 0 5px #4f8ef7);
  }
  .cpd {
    fill: none;
    stroke: #4f8ef7;
    stroke-width: 1;
    transition: stroke 0.9s ease, filter 0.9s ease;
    filter: drop-shadow(0 0 3px #4f8ef7);
  }

  /* Flow / electricity animation */
  @keyframes flowDown {
    from { stroke-dashoffset: 40; }
    to   { stroke-dashoffset: 0; }
  }
  @keyframes flowUp {
    from { stroke-dashoffset: 0; }
    to   { stroke-dashoffset: 40; }
  }
  @keyframes flowRight {
    from { stroke-dashoffset: 30; }
    to   { stroke-dashoffset: 0; }
  }

  .cf {
    stroke: #4f8ef7;
    fill: none;
    stroke-dasharray: 7 13;
    stroke-linecap: round;
    opacity: 0.75;
    transition: stroke 0.9s ease;
    animation: flowDown 2s linear infinite;
  }
  .cf.cf-slow  { animation-duration: 3.2s; }
  .cf.cf-fast  { animation-duration: 1.3s; animation-name: flowRight; }
  .cf.cf-rev   { animation-direction: reverse; }

  /* Hide on narrow screens where the panel overlaps content */
  @media (max-width: 1100px) {
    #circuit-panel { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .cf { animation: none; }
  }
</style>

<script>
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  import gsap from 'gsap';
  gsap.registerPlugin(ScrollTrigger);

  const sectionColors: Record<string, string> = {
    hero:     '#00d4ff',  // cyan electric
    about:    '#06d6a0',  // teal
    projects: '#bf5fff',  // purple
    creative: '#ff2d78',  // magenta
    courses:  '#ff8c00',  // amber
    contact:  '#4f8ef7',  // blue
  };

  function applyColor(color: string) {
    const paths  = document.querySelectorAll<SVGElement>('.cp');
    const dots   = document.querySelectorAll<SVGElement>('.cd');
    const pads   = document.querySelectorAll<SVGElement>('.cpd');
    const flows  = document.querySelectorAll<SVGElement>('.cf');
    const glow3  = `drop-shadow(0 0 3px ${color})`;
    const glow5  = `drop-shadow(0 0 5px ${color})`;

    paths.forEach((el) => { el.style.stroke = color; el.style.filter = glow3; });
    dots.forEach((el)  => { el.style.fill   = color; el.style.filter = glow5; });
    pads.forEach((el)  => { el.style.stroke = color; el.style.filter = glow3; });
    flows.forEach((el) => { el.style.stroke = color; });
  }

  const sections = ['hero', 'about', 'projects', 'creative', 'courses', 'contact'];
  sections.forEach((id) => {
    const el = document.getElementById(id);
    if (!el) return;
    ScrollTrigger.create({
      trigger: el,
      start: 'top 60%',
      end: 'bottom 40%',
      onEnter: () => applyColor(sectionColors[id]),
      onEnterBack: () => applyColor(sectionColors[id]),
    });
  });
</script>
