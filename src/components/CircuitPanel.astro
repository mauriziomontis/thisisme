<div id="circuit-panel" aria-hidden="true">
  <svg id="circuit-svg" viewBox="0 0 80 800" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">

    <!-- ═══════════════════════════════ BACKBONE ══════════════════════════════ -->
    <line class="cp" x1="40" y1="0" x2="40" y2="800" stroke-width="1.5"/>

    <!-- ═══════════════════════════════ GROUP A (0–120) ══════════════════════ -->
    <circle class="cd" cx="40" cy="25" r="3.5"/>
    <line class="cp" x1="40" y1="25" x2="70" y2="25" stroke-width="1.5"/>
    <rect class="cpd" x="67" y="20" width="9" height="9"/>

    <circle class="cd" cx="40" cy="55" r="3.5"/>
    <line class="cp" x1="10" y1="55" x2="40" y2="55" stroke-width="1.5"/>
    <rect class="cpd" x="6" y="50" width="9" height="9"/>

    <circle class="cd" cx="40" cy="90" r="3.5"/>
    <line class="cp" x1="40" y1="90" x2="60" y2="90" stroke-width="1.5"/>
    <line class="cp" x1="60" y1="90" x2="60" y2="112" stroke-width="1.5"/>
    <circle class="cd" cx="60" cy="112" r="3"/>
    <line class="cp" x1="60" y1="112" x2="73" y2="112" stroke-width="1.5"/>
    <rect class="cpd" x="70" y="107" width="8" height="8"/>

    <!-- ═══════════════════════════════ GROUP B (120–240) ═════════════════════ -->
    <circle class="cd" cx="40" cy="140" r="3.5"/>
    <line class="cp" x1="12" y1="140" x2="40" y2="140" stroke-width="1.5"/>

    <circle class="cd" cx="40" cy="170" r="3.5"/>
    <line class="cp" x1="40" y1="170" x2="56" y2="170" stroke-width="1.5"/>
    <line class="cp" x1="56" y1="170" x2="56" y2="196" stroke-width="1.5"/>
    <circle class="cd" cx="56" cy="196" r="3"/>
    <line class="cp" x1="56" y1="196" x2="72" y2="196" stroke-width="1.5"/>
    <rect class="cpd" x="69" y="191" width="8" height="8"/>

    <circle class="cd" cx="40" cy="222" r="3.5"/>
    <line class="cp" x1="18" y1="222" x2="40" y2="222" stroke-width="1.5"/>
    <line class="cp" x1="18" y1="222" x2="18" y2="240" stroke-width="1.5"/>
    <circle class="cd" cx="18" cy="240" r="3"/>

    <!-- ═══════════════════════════════ GROUP C (240–360) ═════════════════════ -->
    <circle class="cd" cx="40" cy="258" r="3.5"/>
    <line class="cp" x1="40" y1="258" x2="70" y2="258" stroke-width="1.5"/>
    <rect class="cpd" x="67" y="253" width="9" height="9"/>

    <circle class="cd" cx="40" cy="285" r="3.5"/>
    <line class="cp" x1="18" y1="285" x2="40" y2="285" stroke-width="1.5"/>
    <line class="cp" x1="18" y1="285" x2="18" y2="306" stroke-width="1.5"/>
    <circle class="cd" cx="18" cy="306" r="3"/>
    <line class="cp" x1="8" y1="306" x2="18" y2="306" stroke-width="1.5"/>

    <circle class="cd" cx="40" cy="318" r="3.5"/>
    <line class="cp" x1="40" y1="318" x2="66" y2="318" stroke-width="1.5"/>

    <circle class="cd" cx="40" cy="352" r="3.5"/>

    <!-- ═══════════════════════════════ GROUP D (360–480) ═════════════════════ -->
    <circle class="cd" cx="40" cy="375" r="3.5"/>
    <line class="cp" x1="10" y1="375" x2="40" y2="375" stroke-width="1.5"/>
    <rect class="cpd" x="6" y="370" width="9" height="9"/>

    <circle class="cd" cx="40" cy="405" r="3.5"/>
    <line class="cp" x1="40" y1="405" x2="59" y2="405" stroke-width="1.5"/>
    <line class="cp" x1="59" y1="405" x2="59" y2="430" stroke-width="1.5"/>
    <circle class="cd" cx="59" cy="430" r="3"/>
    <line class="cp" x1="59" y1="430" x2="73" y2="430" stroke-width="1.5"/>
    <rect class="cpd" x="70" y="425" width="8" height="8"/>

    <circle class="cd" cx="40" cy="452" r="3.5"/>
    <line class="cp" x1="18" y1="452" x2="40" y2="452" stroke-width="1.5"/>

    <circle class="cd" cx="40" cy="476" r="3.5"/>
    <line class="cp" x1="40" y1="476" x2="65" y2="476" stroke-width="1.5"/>

