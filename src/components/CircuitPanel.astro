    <circle class="cd" cx="40" cy="498" r="3.5"/>
    <line class="cp" x1="40" y1="498" x2="71" y2="498" stroke-width="1.5"/>
    <rect class="cpd" x="68" y="493" width="9" height="9"/>

    <circle class="cd" cx="40" cy="526" r="3.5"/>
    <line class="cp" x1="21" y1="526" x2="40" y2="526" stroke-width="1.5"/>
    <line class="cp" x1="21" y1="526" x2="21" y2="550" stroke-width="1.5"/>
    <circle class="cd" cx="21" cy="550" r="3"/>
    <line class="cp" x1="8" y1="550" x2="21" y2="550" stroke-width="1.5"/>

    <circle class="cd" cx="40" cy="572" r="3.5"/>
    <line class="cp" x1="40" y1="572" x2="63" y2="572" stroke-width="1.5"/>
