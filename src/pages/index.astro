---
import Base from '../layouts/Base.astro';
import Cursor from '../components/Cursor.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Projects from '../components/Projects.astro';
import Creative from '../components/Creative.astro';
import Courses from '../components/Courses.astro';
import Labs from '../components/Labs.astro';
import Contact from '../components/Contact.astro';
import CircuitPanel from '../components/CircuitPanel.astro';
import CircuitPanelLeft from '../components/CircuitPanelLeft.astro';
import BackgroundShader from '../components/BackgroundShader.astro';
---

<Base>
  <BackgroundShader />
  <div id="content">
    <Cursor />
    <Nav />
    <CircuitPanel />
    <CircuitPanelLeft />
    <main>
      <Hero />
      <About />
      <Projects />
      <Creative />
      <Courses />
      <Labs />
      <Contact />
    </main>
  </div>
</Base>
